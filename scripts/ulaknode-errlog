#!/bin/bash
# ulaknode-errlog — show stderr error logs for a supervised service
# Usage: ulaknode-errlog <service> [lines]

set -euo pipefail

SERVICE="${1:-}"
LINES="${2:-50}"

usage() {
    echo "Usage: ulaknode-errlog <service> [lines]" >&2
    echo "" >&2
    echo "Services:" >&2
    echo "  postfix    SMTP server" >&2
    echo "  dovecot    IMAP server" >&2
    echo "  rspamd     spam filter" >&2
    echo "  clamav     antivirus daemon" >&2
    echo "  freshclam  ClamAV signature updater" >&2
    echo "" >&2
    echo "Options:" >&2
    echo "  lines  number of lines to show (default: 50)" >&2
    echo "" >&2
    echo "Examples:" >&2
    echo "  ulaknode-errlog postfix" >&2
    echo "  ulaknode-errlog dovecot 100" >&2
    exit 1
}

if [[ "$SERVICE" == "-h" || "$SERVICE" == "--help" || -z "$SERVICE" ]]; then
    usage
fi

if ! [[ "$LINES" =~ ^[0-9]+$ ]] || [[ "$LINES" -eq 0 ]]; then
    echo "Error: lines must be a positive integer." >&2
    exit 1
fi

case "$SERVICE" in
  postfix)   LOG="/var/log/postfix.err" ;;
  dovecot)   LOG="/var/log/dovecot.err" ;;
  rspamd)    LOG="/var/log/rspamd.err" ;;
  clamav)    LOG="/var/log/clamav.err" ;;
  freshclam) LOG="/var/log/freshclam.err" ;;
  *)
    echo "Error: unknown service '$SERVICE'." >&2
    echo "Run 'ulaknode-errlog --help' for usage." >&2
    exit 1
    ;;
esac

if [[ ! -f "$LOG" ]]; then
    echo "Error: log file not found: $LOG" >&2
    exit 1
fi

echo "==> $LOG (last $LINES lines)"
tail -n "$LINES" "$LOG"

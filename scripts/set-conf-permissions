#!/bin/bash
# Fix permissions on config files that services need to read

# Postfix — files must not be group/world writable
chmod -R go-w /etc/postfix/

# Dovecot passwd — readable by dovecot group only
PASSWD="/etc/dovecot/passwd"
if [[ -f "$PASSWD" ]]; then
    chown root:dovecot "$PASSWD"
    chmod 640 "$PASSWD"
fi

# Mail storage — writable by virtual mail user (uid/gid 5000)
chown 5000:5000 /var/mail
chmod 755 /var/mail

# DKIM keys — owned by rspamd
DKIM_DIR="/etc/rspamd/dkim"
if [[ -d "$DKIM_DIR" ]]; then
    chown -R _rspamd:_rspamd "$DKIM_DIR"
    find "$DKIM_DIR" -type d -exec chmod 750 {} \;
    find "$DKIM_DIR" -type f -exec chmod 640 {} \;
fi

# Certs — readable by mail services
CERT_DIR="/etc/ssl/mail"
if [[ -d "$CERT_DIR" ]]; then
    chown root:root "$CERT_DIR"
    chmod 755 "$CERT_DIR"
    chmod 644 "$CERT_DIR/fullchain.pem" 2>/dev/null || true
    chmod 640 "$CERT_DIR/privkey.pem"   2>/dev/null || true
fi
